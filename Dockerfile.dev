FROM rust:1.89-alpine

WORKDIR /workspace

RUN apk add --no-cache \
    bash \
    curl \
    git \
    musl-dev \
    pkgconfig \
    openssl-dev \
    nodejs \
    npm \
  && cargo install wasm-pack

RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

CMD ["sh", "-c", "cd /workspace/wasm-core && wasm-pack build --target web --out-dir pkg && cd /workspace/frontend && bun install && bun run dev --host 0.0.0.0 --port 5173"]
